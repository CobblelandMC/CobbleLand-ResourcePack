{
	"format_version": "1.8.0",
	"animations": {
		"animation.pokestop.idle_closed": {
			"loop": true
		},
		"animation.pokestop.idle_open": {
			"loop": true
		},
		"animation.pokestop.claimed": {
			"loop": true
		},
		"animation.max_mushroom.idle": {
			"loop": true,
			"bones": {
				"body": {
					"rotation": [0, "-math.sin(query.anim_time*2*360)", 0]
				}
			}
		},
		"animation.max_mushroom.hit": {
			"loop": true,
			"animation_length": 1,
			"bones": {
				"body": {
					"scale": {
						"0.0": [1, 1, 1],
						"0.5": [1.2, 1.2, 1.2],
						"0.75": [1, 1, 1]
					}
				}
			}
		},
		"animation.max_mushroom.mined": {
			"loop": true,
			"bones": {
				"body": {
					"rotation": [0, "-math.sin(query.anim_time*2*360)", 0]
				}
			}
		}
	}
}